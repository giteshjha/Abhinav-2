# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this from secrets.
# For Vercel/External hosting, set one of these in your environment variables dashboard:
# - GEMINI_API_KEY
# - VITE_GEMINI_API_KEY
# - GEMMA_API_KEY
GEMINI_API_KEY="your_api_key_here"

# Optional: override the chat model. By default the app uses gemma-4-26b-a4b-it.
# If Gemma 4 is unavailable for a request, the app automatically falls back to
# Gemma 3, then Gemini Flash-Lite and Flash variants.
GEMINI_CHAT_MODEL="gemma-4-26b-a4b-it"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
